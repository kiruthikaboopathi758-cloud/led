<!DOCTYPE html>
<html>
<head>
    <title>Industrial IoT Dashboard</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#eceff1;
            text-align:center;
        }

        .container{
            width:450px;
            margin:50px auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h1{
            color:#1565c0;
        }

        .card{
            background:#f5f5f5;
            padding:15px;
            margin:15px;
            border-radius:8px;
            font-size:22px;
            font-weight:bold;
        }

        .normal{
            color:green;
        }

        .warning{
            color:orange;
        }

        .danger{
            color:red;
        }
    </style>
</head>

<body>

<div class="container">

<h1>🏭 Industrial IoT Dashboard</h1>

<div class="card">
🌡 Machine Temperature :
<span id="temp">--</span> °C
</div>

<div class="card">
📳 Vibration :
<span id="vibration">--</span> Hz
</div>

<div class="card">
⚙ Machine Status :
<span id="status" class="normal">Running</span>
</div>

</div>

<script>

const ip = "http://192.168.1.100";

function updateData()
{
    fetch(ip + "/machine")
    .then(response => response.json())
    .then(data => {

        document.getElementById("temp").innerHTML = data.temperature;

        document.getElementById("vibration").innerHTML = data.vibration;

        let status = document.getElementById("status");

        status.innerHTML = data.status;

        status.className = "";

        if(data.status == "Running")
            status.classList.add("normal");

        else if(data.status == "Maintenance")
            status.classList.add("warning");

        else
            status.classList.add("danger");

    });
}

updateData();

setInterval(updateData,3000);

</script>

</body>
</html>