<!DOCTYPE html>
<html>
<head>
    <title>IoT LED Control</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            text-align:center;
            background:#f4f4f4;
            margin-top:100px;
        }

        h1{
            color:#333;
        }

        button{
            width:150px;
            padding:15px;
            margin:10px;
            font-size:18px;
            border:none;
            border-radius:8px;
            cursor:pointer;
        }

        .on{
            background:green;
            color:white;
        }

        .off{
            background:red;
            color:white;
        }
    </style>
</head>

<body>

<h1>IoT LED Control Dashboard</h1>

<button class="on" onclick="ledOn()">LED ON</button>

<button class="off" onclick="ledOff()">LED OFF</button>

<script>

function ledOn()
{
    fetch("http://192.168.1.100/on");
}

function ledOff()
{
    fetch("http://192.168.1.100/off");
}

</script>

</body>
</html>
