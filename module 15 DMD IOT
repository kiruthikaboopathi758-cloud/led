<!DOCTYPE html>
<html>
<head>
    <title>IoT Device Monitoring Dashboard</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#eef5f9;
            text-align:center;
        }

        .container{
            width:90%;
            max-width:900px;
            margin:40px auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h1{
            color:#1565c0;
        }

        table{
            width:100%;
            border-collapse:collapse;
            margin-top:20px;
        }

        th, td{
            border:1px solid #ccc;
            padding:12px;
            text-align:center;
        }

        th{
            background:#1565c0;
            color:white;
        }

        tr:nth-child(even){
            background:#f5f5f5;
        }

        .online{
            color:green;
            font-weight:bold;
        }

        .offline{
            color:red;
            font-weight:bold;
        }
    </style>
</head>

<body>

<div class="container">

<h1>📡 IoT Device Monitoring Dashboard</h1>

<table>

<thead>

<tr>
<th>Device ID</th>
<th>Status</th>
<th>Last Update</th>
<th>Temperature (°C)</th>
<th>Humidity (%)</th>
</tr>

</thead>

<tbody id="deviceTable">

</tbody>

</table>

</div>

<script>

const ip = "http://192.168.1.100";

function loadDevices()
{

fetch(ip + "/devices")

.then(response => response.json())

.then(data => {

let rows = "";

data.forEach(device => {

rows += `
<tr>

<td>${device.id}</td>

<td class="${device.status=="Online"?"online":"offline"}">

${device.status}

</td>

<td>${device.lastUpdate}</td>

<td>${device.temperature}</td>

<td>${device.humidity}</td>

</tr>
`;

});

document.getElementById("deviceTable").innerHTML = rows;

});

}

loadDevices();

setInterval(loadDevices,3000);

</script>

</body>
</html>
