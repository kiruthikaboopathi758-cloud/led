<!DOCTYPE html>
<html>
<head>
    <title>Smart Parking Dashboard</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#eef2f7;
            text-align:center;
        }

        .container{
            width:500px;
            margin:40px auto;
            background:white;
            padding:20px;
            border-radius:10px;
            box-shadow:0 0 10px gray;
        }

        h1{
            color:#1565c0;
        }

        .slot{
            display:flex;
            justify-content:space-between;
            align-items:center;
            background:#f4f4f4;
            margin:10px 0;
            padding:15px;
            border-radius:8px;
            font-size:20px;
            font-weight:bold;
        }

        .available{
            color:green;
        }

        .occupied{
            color:red;
        }

        .summary{
            margin-top:20px;
            font-size:22px;
            font-weight:bold;
            color:#333;
        }
    </style>
</head>

<body>

<div class="container">

<h1>🅿 Smart Parking Dashboard</h1>

<div id="parkingSlots"></div>

<div class="summary">
Available Slots:
<span id="available">0</span>
<br><br>
Occupied Slots:
<span id="occupied">0</span>
</div>

</div>

<script>

const ip = "http://192.168.1.100";

function loadParking()
{
    fetch(ip + "/parking")
    .then(response => response.json())
    .then(data => {

        let html = "";
        let available = 0;
        let occupied = 0;

        data.forEach(slot => {

            if(slot.status == "Available")
                available++;
            else
                occupied++;

            html += `
            <div class="slot">
                <span>Slot ${slot.slot}</span>

                <span class="${slot.status=="Available"?"available":"occupied"}">
                ${slot.status}
                </span>
            </div>
            `;
        });

        document.getElementById("parkingSlots").innerHTML = html;
        document.getElementById("available").innerHTML = available;
        document.getElementById("occupied").innerHTML = occupied;

    });
}

loadParking();

setInterval(loadParking,3000);

</script>

</body>
</html>